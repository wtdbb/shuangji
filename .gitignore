# ===== Obsidian =====
# 工作区状态(频繁变动、与本机相关,不需要版本控制)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache

# Obsidian 回收站
.trash/

# ===== Claudian =====
# 会话元数据(临时、与单次对话相关)
.claudian/sessions/

# ===== 微信抓取(含 token / 临时状态,不入库) =====
.claude/wechat/feeds.txt
.claude/wechat/seen.json

# ===== Skill 存放 =====
# 真实文件放在 vault 根目录的 skill/;.claude/skills 是指向它的 junction
# 忽略 junction 视图,避免 git 重复跟踪同一批文件
/.claude/skills/
# 所有 skill 的密钥文件绝不入库
/skill/**/.env

# ===== 系统/临时文件 =====
.DS_Store
Thumbs.db
desktop.ini
*.tmp
~$*

# 导入暂存目录(临时转换用)
_导入暂存/
