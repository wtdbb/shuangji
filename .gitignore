# ===== Obsidian =====
# 工作区状态(频繁变动、与本机相关,不需要版本控制)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache

# Obsidian 回收站
.trash/

# ===== Claudian =====
# 会话元数据(临时、与单次对话相关)
.claudian/sessions/

# ===== 微信抓取(含 token / 临时状态,不入库) =====
.claude/wechat/feeds.txt
.claude/wechat/seen.json

# ===== Skill 存放 =====
# skill/ 是独立 git 仓库(只有它推送到 GitHub);vault 本地仓库不跟踪它
/skill/
# .claude/skills 是指向 skill/ 的 junction,vault 仓库忽略
/.claude/skills/

# ===== 系统/临时文件 =====
.DS_Store
Thumbs.db
desktop.ini
*.tmp
~$*

# 导入暂存目录(临时转换用)
_导入暂存/
.obsidian/webviewer.json

# ===== Local AI/runtime temporary files =====
/.claude/scrapling-venv/
/.claude/logs/
/.claude/huaban-*.html
/.claude/backup-Home-before-*.md


# Local scratch files generated by automation
/.claude/tmp-*
/.claudian/*.bak-*

