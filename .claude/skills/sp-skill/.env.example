# ASR 后端选择：faster-whisper（默认）或 volcengine
ASR_BACKEND=faster-whisper

# 视频解析/下载代理 - 用于获取抖音/小红书/B站视频信息和下载地址（YouTube 不需要）
# 推荐：AI Douyin，注册后可用免费额度试用；成功解析下载直链后扣 1 积分
# 配置教程: docs/ai-douyin-setup.md
VIDEO_INFO_PROVIDER=ai-douyin
AI_DOUYIN_API_BASE=https://ai-douyin.top9.cc
AI_DOUYIN_API_KEY=your_ai_douyin_api_key

# 高级/自托管：如需绕过 AI Douyin，可改为 VIDEO_INFO_PROVIDER=tikhub 并配置自己的 TikHub Token
# 申请教程: docs/tikhub-setup.md
TIKHUB_TOKEN=

# faster-whisper - 本地语音转写运行时参数（ASR_BACKEND=faster-whisper 时生效）
# 安装教程: docs/faster-whisper-setup.md
FW_MODEL_SIZE=small
FW_DEVICE=auto
FW_COMPUTE_TYPE=
FW_PYTHON=

# 火山引擎 VC - 云端字幕转写参数（ASR_BACKEND=volcengine 时生效）
# 安装教程: docs/bytedance-vc-setup.md
BYTEDANCE_VC_TOKEN=your_bytedance_vc_token
BYTEDANCE_VC_APPID=your_bytedance_vc_appid
