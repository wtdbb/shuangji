{
  "command_timeout": 5,
  "templates_folder": "Daily notes/Templates",
  "templates_pairs": [
    [
      "",
      ""
    ]
  ],
  "trigger_on_file_creation": true,
  "auto_jump_to_cursor": false,
  "enable_system_commands": false,
  "shell_path": "",
  "user_scripts_folder": "",
  "enable_folder_templates": true,
  "folder_templates": [
    {
      "folder": "Daily notes/Calendar/Journal/Daily",
      "template": "Daily notes/Templates/Daily-TEMPLATE.md"
    },
    {
      "folder": "Daily notes/Calendar/Journal/Weekly",
      "template": "Daily notes/Templates/Weekly-TEMPLATE.md"
    },
    {
      "folder": "Daily notes/Calendar/Journal/Month",
      "template": "Daily notes/Templates/Monthly-TEMPLATE.md"
    },
    {
      "folder": "Daily notes/Calendar/Journal/Quarterly",
      "template": "Daily notes/Templates/Quarterly-TEMPLATE.md"
    },
    {
      "folder": "Daily notes/Calendar/Journal/Yearly",
      "template": "Daily notes/Templates/Yearly-TEMPLATE.md"
    },
    {
      "folder": "Daily notes/Calendar/Meetings",
      "template": "Daily notes/Templates/Meeting-TEMPLATE.md"
    }
  ],
  "enable_file_templates": false,
  "file_templates": [
    {
      "regex": ".*",
      "template": ""
    }
  ],
  "syntax_highlighting": true,
  "syntax_highlighting_mobile": false,
  "enabled_templates_hotkeys": [
    "Daily notes/Templates/Meeting-TEMPLATE.md"
  ],
  "startup_templates": [
    ""
  ],
  "intellisense_render": 1,
  "ignore_folders_on_creation": [
    {
      "folder": ""
    }
  ]
}
